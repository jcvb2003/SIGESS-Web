# Handle line endings automatically
* text=auto

# Force LF for source files (crucial for Linux environments like Supabase Edge Functions)
*.ts text eol=lf
*.tsx text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
