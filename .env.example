# =============================================================================
# SIGESS — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env com valores reais para o repositório.
#
# Convenção de nomes (obrigatório seguir para o sistema de tenants funcionar):
#
#   VITE_SUPABASE_URL_[CÓDIGO]        → URL do projeto Supabase do cliente
#   VITE_SUPABASE_ANON_KEY_[CÓDIGO]   → Chave anon pública do cliente
#   VITE_SUPABASE_LABEL_[CÓDIGO]      → Nome amigável (opcional, ex: "Colônia Z-2")
#
# O [CÓDIGO] vira o identificador digitado no login:
#   VITE_SUPABASE_URL_Z2              → tenant "z2"
#   VITE_SUPABASE_URL_SINPESCA_BREVES → tenant "sinpesca-breves"
#
# Para adicionar um novo cliente basta o processo de onboarding (setup-client.ts)
# injetar as env vars no Vercel. Este arquivo não precisa ser editado.
# =============================================================================

# -------------------------------------
# Tenant: [CÓDIGO] — Nome do Cliente
# -------------------------------------
VITE_SUPABASE_URL_[CODIGO]=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY_[CODIGO]=eyJ...
# VITE_SUPABASE_LABEL_[CODIGO]=Nome Amigável  ← opcional

# -------------------------------------
# Tenant: Z2 — Colônia Z-2 de Salvaterra
# -------------------------------------
VITE_SUPABASE_URL_Z2=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY_Z2=eyJ...
# VITE_SUPABASE_LABEL_Z2=Colônia Z-2 de Salvaterra

# -------------------------------------
# Tenant: SINPESCA_BREVES — SINPESCA Polo Breves
# -------------------------------------
VITE_SUPABASE_URL_SINPESCA_BREVES=https://yyy.supabase.co
VITE_SUPABASE_ANON_KEY_SINPESCA_BREVES=eyJ...
# VITE_SUPABASE_LABEL_SINPESCA_BREVES=SINPESCA — Polo Breves Eliseu

# -------------------------------------
# Integrações globais
# -------------------------------------
RESEND_API_KEY=re_...
