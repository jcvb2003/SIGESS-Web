# =============================================================================
# SIGESS - Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env com valores reais para o repositorio.
#
# O caminho principal para novos tenants agora e o Dynamic Config Resolver.
# As env vars por tenant abaixo continuam suportadas como compatibilidade e
# fallback para tenants antigos ou ambientes locais especificos.
#
# Convencao legada de nomes:
#
#   VITE_SUPABASE_URL_[CODIGO]        -> URL do projeto Supabase do cliente
#   VITE_SUPABASE_ANON_KEY_[CODIGO]   -> Chave anon publica do cliente
#   VITE_SUPABASE_LABEL_[CODIGO]      -> Nome amigavel (opcional)
#
# O [CODIGO] vira o identificador digitado no login:
#   VITE_SUPABASE_URL_Z2              -> tenant "z2"
#   VITE_SUPABASE_URL_SINPESCA_BREVES -> tenant "sinpesca-breves"
# =============================================================================

# -------------------------------------
# Tenant: [CODIGO] - Nome do Cliente
# -------------------------------------
VITE_SUPABASE_URL_[CODIGO]=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY_[CODIGO]=eyJ...
# VITE_SUPABASE_LABEL_[CODIGO]=Nome Amigavel

# -------------------------------------
# Tenant: Z2 - Colonia Z-2 de Salvaterra
# -------------------------------------
VITE_SUPABASE_URL_Z2=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY_Z2=eyJ...
# VITE_SUPABASE_LABEL_Z2=Colonia Z-2 de Salvaterra

# -------------------------------------
# Tenant: SINPESCA_BREVES - SINPESCA Polo Breves
# -------------------------------------
VITE_SUPABASE_URL_SINPESCA_BREVES=https://yyy.supabase.co
VITE_SUPABASE_ANON_KEY_SINPESCA_BREVES=eyJ...
# VITE_SUPABASE_LABEL_SINPESCA_BREVES=SINPESCA - Polo Breves Eliseu

# -------------------------------------
# Integracoes globais
# -------------------------------------
RESEND_API_KEY=re_...

# -------------------------------------
# Dynamic Config Resolver
# -------------------------------------
# URL da Edge Function tenant-config no projeto Admin.
# Esta e a configuracao principal para resolucao dinamica de novos tenants,
# sem depender de injecao de env vars nem redeploy no Vercel.
VITE_ADMIN_TENANT_CONFIG_URL=https://vdwupmfpfkaempsiqfgb.supabase.co/functions/v1/tenant-config
